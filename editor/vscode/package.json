{
  "name": "cowel",
  "displayName": "COWEL",
  "version": "0.9.2-pre",
  "description": "Syntax highlighting and language support for Compact Web Language (COWEL)",
  "main": "./out/extension.js",
  "scripts": {
    "test": "ts-node tests/test-runner.ts && ts-node --project tests/tsconfig.json tests/folding.test.ts",
    "build": "tsc -p tsconfig.json && vsce package",
    "clean": "rm -f *.vsix",
    "rebuild": "npm run clean && npm run build",
    "dev": "code --extensionDevelopmentPath=. test.cow"
  },
  "keywords": [
    "cowel",
    "markup"
  ],
  "categories": [
    "Programming Languages"
  ],
  "author": {
    "name": "Jan Schultke",
    "email": "me@eisenwave.net",
    "url": "https://github.com/eisenwave/"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/eisenwave/cowel/issues"
  },
  "type": "commonjs",
  "publisher": "cowel",
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.9.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.1"
  },
  "engines": {
    "vscode": "^1.80.0",
    "node": "^20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/eisenwave/cowel"
  },
  "icon": "./icons/extension.png",
  "contributes": {
    "languages": [
      {
        "id": "cowel",
        "aliases": [
          "COWEL",
          "cowel"
        ],
        "extensions": [
          ".cow",
          ".cowel"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/file.svg",
          "dark": "./icons/file.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "cowel",
        "scopeName": "source.cowel",
        "path": "./syntaxes/cowel.tmLanguage.json",
        "tokenTypes": {
          "punctuation.section.arguments.begin.cowel": "other",
          "punctuation.section.arguments.end.cowel": "other",
          "punctuation.section.content.begin.cowel": "other",
          "punctuation.section.content.end.cowel": "other",
          "punctuation.definition.template-expression.begin.cowel": "other",
          "punctuation.definition.template-expression.end.cowel": "other",
          "support.function.directive.cowel": "other"
        },
        "balancedBracketScopes": [
          "*"
        ],
        "unbalancedBracketScopes": [
          "constant.character.escape.cowel",
          "invalid.illegal.escape.cowel",
          "punctuation.definition.template-expression"
        ]
      }
    ]
  }
}
