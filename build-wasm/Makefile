generated/wg21_json.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/cowel-wasm.dir/build.make CMakeFiles/cowel-wasm.dir/generated/wg21_json.cpp.i
	$(MAKE) $(MAKESILENT) -f CMakeFiles/cowel-lsp.dir/build.make CMakeFiles/cowel-lsp.dir/generated/wg21_json.cpp.i
.PHONY : generated/wg21_json.cpp.i

generated/wg21_json.s: generated/wg21_json.cpp.s
.PHONY : generated/wg21_json.s

# target to generate assembly for a file
generated/wg21_json.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/cowel-wasm.dir/build.make CMakeFiles/cowel-wasm.dir/generated/wg21_json.cpp.s
	$(MAKE) $(MAKESILENT) -f CMakeFiles/cowel-lsp.dir/build.make CMakeFiles/cowel-lsp.dir/generated/wg21_json.cpp.s
.PHONY : generated/wg21_json.cpp.s

