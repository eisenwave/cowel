\test_input{
\__typeof(cowel_rem_to_pos_inf(1, 1))

\cowel_rem_to_pos_inf(-2, -2)
\cowel_rem_to_pos_inf(-2, -1)
\cowel_rem_to_pos_inf(-2, 1)
\cowel_rem_to_pos_inf(-2, 2)

\cowel_rem_to_pos_inf(-1, -2)
\cowel_rem_to_pos_inf(-1, -1)
\cowel_rem_to_pos_inf(-1, 1)
\cowel_rem_to_pos_inf(-1, 2)

\cowel_rem_to_pos_inf( 0, -2)
\cowel_rem_to_pos_inf( 0, -1)
\cowel_rem_to_pos_inf( 0, 1)
\cowel_rem_to_pos_inf( 0, 2)

\cowel_rem_to_pos_inf( 1, -2)
\cowel_rem_to_pos_inf( 1, -1)
\cowel_rem_to_pos_inf( 1, 1)
\cowel_rem_to_pos_inf( 1, 2)

\cowel_rem_to_pos_inf( 2, -2)
\cowel_rem_to_pos_inf( 2, -1)
\cowel_rem_to_pos_inf( 2, 1)
\cowel_rem_to_pos_inf( 2, 2)

\cowel_rem_to_pos_inf( 10,  0x100000000000000000000000000000000000000000000000000)
\cowel_rem_to_pos_inf( 10, -0x100000000000000000000000000000000000000000000000000)
\cowel_rem_to_pos_inf(-10,  0x100000000000000000000000000000000000000000000000000)
\cowel_rem_to_pos_inf(-10, -0x100000000000000000000000000000000000000000000000000)

\cowel_rem_to_pos_inf(8, 2)
\cowel_rem_to_pos_inf(2, 8)
\test_expect_error("arithmetic.div-by-zero"){\cowel_rem_to_pos_inf(1, 0)}
}

