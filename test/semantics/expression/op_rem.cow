\test_input{
\__typeof(5 % 2)

\cowel_pos(-2 % -2)
\cowel_pos(-2 % -1)
\cowel_pos(-2 %  1)
\cowel_pos(-2 %  2)

\cowel_pos(-1 % -2)
\cowel_pos(-1 % -1)
\cowel_pos(-1 %  1)
\cowel_pos(-1 %  2)

\cowel_pos( 0 % -2)
\cowel_pos( 0 % -1)
\cowel_pos( 0 %  1)
\cowel_pos( 0 %  2)

\cowel_pos( 1 % -2)
\cowel_pos( 1 % -1)
\cowel_pos( 1 %  1)
\cowel_pos( 1 %  2)

\cowel_pos( 2 % -2)
\cowel_pos( 2 % -1)
\cowel_pos( 2 %  1)
\cowel_pos( 2 %  2)

\cowel_pos(8 % 2)
\cowel_pos(2 % 8)
\test_expect_error("arithmetic.div-by-zero"){\cowel_pos(1 % 0)}
}

