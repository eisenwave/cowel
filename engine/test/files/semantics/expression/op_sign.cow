\test_input{
\__typeof(+1)
\__typeof(-1)
\__typeof(+1.0)
\__typeof(-1.0)

\cowel_pos(+1)
\cowel_pos(-1)
\cowel_pos(+1.0)
\cowel_pos(-1.0)

\test_expect_error("type.mismatch"){\cowel_pos(+true)}
\test_expect_error("type.mismatch"){\cowel_pos(-null)}
}

\test_output{
int
int
float
float

1
-1
1
-1

<error->\cowel_pos(+true)</error->
<error->\cowel_pos(-null)</error->
}
