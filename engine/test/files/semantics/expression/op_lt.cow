\__typeof(1 < 2)

\cowel_and(0 < 0)
\cowel_and(0 < 1)
\cowel_and(1 < 0)
\cowel_and(1 < 1)

\cowel_and( 0x100000000000000000000000000000000000000000000000000 <  0)
\cowel_and(-0x100000000000000000000000000000000000000000000000000 <  0)
\cowel_and( 0x100000000000000000000000000000000000000000000000000 <  0x100000000000000000000000000000000000000000000000000)
\cowel_and( 0x100000000000000000000000000000000000000000000000000 < -0x100000000000000000000000000000000000000000000000000)
\cowel_and(-0x100000000000000000000000000000000000000000000000000 <  0x100000000000000000000000000000000000000000000000000)
\cowel_and(-0x100000000000000000000000000000000000000000000000000 < -0x100000000000000000000000000000000000000000000000000)

\cowel_and(0.0 < 0.0)
\cowel_and(1.0 < 0.0)
\cowel_and(0.0 < 1.0)
\cowel_and(1.0 < 1.0)
\cowel_and(-0.0 < 0.0)
\cowel_and(0.0 < -0.0)
\cowel_and(-0.0 < -0.0)

\cowel_and("" < "")
\cowel_and("x" < "")
\cowel_and("" < "x")
\cowel_and("x" < "x")
\cowel_and("x" < "y")
\cowel_and("y" < "x")

\test_expect_error("type.mismatch"){\(true < false)}
\test_expect_error("type.mismatch"){\(1 < true)}
\test_expect_error("type.mismatch"){\(1 < 1.0)}
}

