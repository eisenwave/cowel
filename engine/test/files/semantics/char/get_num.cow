\test_input{
\cowel_char_get_num("A")
\cowel_char_get_num("0")

\test_expect_warning("ignored.input"){\cowel_char_get_num("abc")}

\test_expect_error("type.mismatch"){\cowel_char_get_num()}
\test_expect_error("char.blank"){\cowel_char_get_num("")}
}

\test_output{
65
48

97

<error->\cowel_char_get_num()</error->
<error->\cowel_char_get_num("")</error->
}
