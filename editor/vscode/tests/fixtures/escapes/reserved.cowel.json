{
  "description": "Test reserved (invalid) escape sequences",
  "assertions": [
    {
      "type": "top-scope",
      "line": 0,
      "col": 0,
      "expected": "invalid.illegal.escape.cowel",
      "description": "\\! is a reserved escape"
    },
    {
      "type": "top-scope",
      "line": 6,
      "col": 0,
      "expected": "invalid.illegal.escape.cowel",
      "description": "\\) is a reserved escape"
    },
    {
      "type": "top-scope",
      "line": 12,
      "col": 0,
      "expected": "invalid.illegal.escape.cowel",
      "description": "\\0 (digit) is a reserved escape"
    },
    {
      "type": "top-scope",
      "line": 25,
      "col": 0,
      "expected": "invalid.illegal.escape.cowel",
      "description": "\\[ is a reserved escape"
    },
    {
      "type": "top-scope",
      "line": 33,
      "col": 0,
      "expected": "invalid.illegal.escape.cowel",
      "description": "Unicode flag escape stays invalid"
    }
  ]
}
