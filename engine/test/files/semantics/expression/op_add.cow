\test_input{
\__typeof(1 + 2)
\__typeof(1.0 + 2.0)

\cowel_pos(8 + 2)
\cowel_pos(8 + 2 + 5)
\cowel_pos(2 + 8)
\cowel_pos(2 + -8)

\cowel_pos(0 + 0)
\cowel_pos(1 + 1)
\cowel_pos(1 + -1)

\cowel_pos(-0x40000000000000000000000000000000 + -0x40000000000000000000000000000000)
\cowel_pos( 0x40000000000000000000000000000000 + -0x40000000000000000000000000000000)
\cowel_pos(-0x40000000000000000000000000000000 +  0x40000000000000000000000000000000)
\cowel_pos(-0x40000000000000000000000000000000 + -0x40000000000000000000000000000000)

\cowel_pos( 0x100000000000000000000000000000000000000000000000000 +  0x100000000000000000000000000000000000000000000000000)
\cowel_pos( 0x100000000000000000000000000000000000000000000000000 + -0x100000000000000000000000000000000000000000000000000)
\cowel_pos(-0x100000000000000000000000000000000000000000000000000 +  0x100000000000000000000000000000000000000000000000000)
\cowel_pos(-0x100000000000000000000000000000000000000000000000000 + -0x100000000000000000000000000000000000000000000000000)

\cowel_pos( 0.0 +  0.0)
\cowel_pos(-0.0 +  0.0)
\cowel_pos( 0.0 + -0.0)
\cowel_pos(-0.0 + -0.0)

\cowel_pos( 1.0 +  1.0)
\cowel_pos(-1.0 +  1.0)
\cowel_pos( 1.0 + -1.0)
\cowel_pos(-1.0 + -1.0)

\cowel_pos(8.0 + 2.0)
\cowel_pos(8.0 + 2.0 + 5.0)
\cowel_pos(2.0 + 8.0)
\cowel_pos(2.0 + -8.0)

\cowel_pos(infinity + 0.0)
\cowel_pos(infinity + 1.0)
\cowel_pos(infinity + infinity)

\cowel_pos(-infinity + 0.0)
\cowel_pos(-infinity + 1.0)
\cowel_pos(-infinity + -infinity)

\cowel_pos(-infinity + infinity)
\cowel_pos(infinity + -infinity)

\cowel_pos(cowel_reinterpret_as_float(0x7ff8000000000000) + -infinity)
\cowel_pos(cowel_reinterpret_as_float(0x7ff8000000000000) + -1.0)
\cowel_pos(cowel_reinterpret_as_float(0x7ff8000000000000) + -0.5)
\cowel_pos(cowel_reinterpret_as_float(0x7ff8000000000000) + -0.0)
\cowel_pos(cowel_reinterpret_as_float(0x7ff8000000000000) +  0.0)
\cowel_pos(cowel_reinterpret_as_float(0x7ff8000000000000) +  0.5)
\cowel_pos(cowel_reinterpret_as_float(0x7ff8000000000000) +  1.0)
\cowel_pos(cowel_reinterpret_as_float(0x7ff8000000000000) +  infinity)
\cowel_pos(cowel_reinterpret_as_float(0x7ff8000000000000) +  cowel_reinterpret_as_float(0x7ff8000000000000))

\test_expect_error("type.mismatch"){\cowel_pos(true + true)}
\test_expect_error("type.mismatch"){\cowel_pos(1 + 1.0)}
}

