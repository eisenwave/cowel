{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Markdown COWEL Code Block Injection",
  "scopeName": "markdown.cowel.codeblock",
  "injectionSelector": "L:text.html.markdown",
  "patterns": [
    { "include": "#fenced-code-block-cowel" }
  ],
  "repository": {
    "fenced-code-block-cowel": {
      "name": "markup.fenced_code.block.markdown",
      "begin": "(^|\\G)(\\s*)(`{3,}|~{3,})\\s*((?i:cowel|cow))\\s*$",
      "beginCaptures": {
        "3": { "name": "punctuation.definition.fenced.markdown" },
        "4": { "name": "entity.name.language.cowel.markdown" }
      },
      "end": "(^|\\G)(\\s*)(\\3)\\s*$",
      "endCaptures": {
        "3": { "name": "punctuation.definition.fenced.markdown" }
      },
      "contentName": "meta.embedded.block.cowel",
      "patterns": [
        { "include": "source.cowel" }
      ]
    }
  }
}
