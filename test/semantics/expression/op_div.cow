\test_input{
\__typeof(0.0 / 0.0)

\cowel_pos( 0.0 /  0.0)
\cowel_pos(-0.0 /  0.0)
\cowel_pos( 0.0 / -0.0)
\cowel_pos(-0.0 / -0.0)

\cowel_pos( 1.0 /  1.0)
\cowel_pos(-1.0 /  1.0)
\cowel_pos( 1.0 / -1.0)
\cowel_pos(-1.0 / -1.0)

\cowel_pos(8.0 / 2.0)
\cowel_pos(8.0 / 2.0 / 5.0)
\cowel_pos(2.0 / 8.0)
\cowel_pos(2.0 / -8.0)

\cowel_pos(infinity / 0.0)
\cowel_pos(infinity / 1.0)
\cowel_pos(infinity / infinity)

\cowel_pos(-infinity / 0.0)
\cowel_pos(-infinity / 1.0)
\cowel_pos(-infinity / -infinity)

\cowel_pos(-infinity / infinity)
\cowel_pos(infinity / -infinity)

\cowel_pos(cowel_reinterpret_as_float(0x7ff8000000000000) / -infinity)
\cowel_pos(cowel_reinterpret_as_float(0x7ff8000000000000) / -1.0)
\cowel_pos(cowel_reinterpret_as_float(0x7ff8000000000000) / -0.5)
\cowel_pos(cowel_reinterpret_as_float(0x7ff8000000000000) / -0.0)
\cowel_pos(cowel_reinterpret_as_float(0x7ff8000000000000) /  0.0)
\cowel_pos(cowel_reinterpret_as_float(0x7ff8000000000000) /  0.5)
\cowel_pos(cowel_reinterpret_as_float(0x7ff8000000000000) /  1.0)
\cowel_pos(cowel_reinterpret_as_float(0x7ff8000000000000) /  infinity)
\cowel_pos(cowel_reinterpret_as_float(0x7ff8000000000000) /  cowel_reinterpret_as_float(0x7ff8000000000000))

\test_expect_error("type.mismatch"){\cowel_pos(1 / 0)}
}

\test_output{
float

NaN
NaN
NaN
NaN

1
-1
-1
1

4
0.8
0.25
-0.25

infinity
infinity
NaN

-infinity
-infinity
NaN

NaN
NaN

NaN
NaN
NaN
NaN
NaN
NaN
NaN
NaN
NaN

<error->\cowel_pos(1 / 0)</error->
}
