\test_input{
\__typeof(cowel_str_substr("", 0))

\cowel_str_substr("", 0)
\cowel_str_substr("awoo", 0)
\cowel_str_substr("awoo", 1)
\cowel_str_substr("awoo", 1, 2)
\cowel_str_substr("awoo", 2, null)
\cowel_str_substr("awoo", 4, 0)

\cowel_str_substr("αβγ", 1)
\cowel_str_substr("αβγ", 1, 1)
\cowel_str_substr("🇩🇪x", 1, 1)
\cowel_str_substr("🇩🇪x", 2, 1)

\test_expect_error("str.substr.range"){\cowel_str_substr("awoo", -1)}
\test_expect_error("str.substr.range"){\cowel_str_substr("awoo", 5)}
\test_expect_error("str.substr.range"){\cowel_str_substr("awoo", 3, 2)}
\test_expect_error("str.substr.range"){\cowel_str_substr("awoo", 0, -1)}

\test_expect_error("str.substr.range"){\cowel_str_substr("αβγ", -1)}
\test_expect_error("str.substr.range"){\cowel_str_substr("αβγ", 4)}
\test_expect_error("str.substr.range"){\cowel_str_substr("αβγ", 2, 2)}
\test_expect_error("str.substr.range"){\cowel_str_substr("αβγ", 0, -1)}

\test_expect_error("str.substr.range"){\cowel_str_substr("🇩🇪x", -1)}
\test_expect_error("str.substr.range"){\cowel_str_substr("🇩🇪x", 4)}
\test_expect_error("str.substr.range"){\cowel_str_substr("🇩🇪x", 2, 2)}
\test_expect_error("str.substr.range"){\cowel_str_substr("🇩🇪x", 0, -1)}
}

\test_output{
str


awoo
woo
wo
oo


βγ
β
🇪
x

